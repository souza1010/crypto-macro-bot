# ══════════════════════════════════════════════════
#   CRYPTO MACRO RADAR — Configurações
#   Renomeie este arquivo para: .env
#   NUNCA compartilhe este arquivo com ninguém!
# ══════════════════════════════════════════════════

# ── 1. TOKEN DO BOT TELEGRAM ───────────────────────
# Obtenha conversando com @BotFather no Telegram
# Exemplo: 7412345678:AAHdqTcvCH1vGWJxfSeofSAs0K5PALDsaw
TELEGRAM_TOKEN=SEU_TOKEN_AQUI

# ── 2. SEU CHAT ID PESSOAL ─────────────────────────
# Para descobrir: inicie o bot e envie /start
# O bot irá exibir seu Chat ID automaticamente
# Exemplo: 123456789
TELEGRAM_CHAT_ID=SEU_CHAT_ID_AQUI

# ── 3. CHAVE DA API ANTHROPIC (Claude IA) ──────────
# Obtenha em: https://console.anthropic.com
# Necessária para análise com IA em português
# Exemplo: sk-ant-api03-...
ANTHROPIC_API_KEY=SUA_CHAVE_ANTHROPIC_AQUI
